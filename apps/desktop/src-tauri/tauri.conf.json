{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Portal do Psi",
  "version": "1.0.0",
  "identifier": "br.com.portaldopsi.app",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Portal do Psi",
        "url": "https://portaldopsi.com.br",
        "width": 1200,
        "height": 800,
        "minWidth": 480,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
