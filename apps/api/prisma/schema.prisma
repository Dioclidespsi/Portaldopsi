/// "native" = Windows local (dev); "debian-openssl-3.0.x" = Linux containers como
/// Render/Railway. Sem o segundo, o build gerado localmente não roda no servidor.
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PSICOLOGO_TITULAR
  SECRETARIA
  SUPERVISOR
  PACIENTE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

/// CLINICA = tenant com paciente/prontuário/agenda ativos, exige psicólogo com
/// CRP verificado. ESTUDANTE = conta só para comprar/estudar curso avulso no
/// Marketplace — mesmo sistema de auth, sem acesso a nenhum módulo clínico.
enum TenantKind {
  CLINICA
  ESTUDANTE
}

enum CrpStatus {
  NAO_ENVIADO
  EM_ANALISE
  VERIFICADO
  REJEITADO
}

/// Gate independente do CrpStatus — CRP já é verificado no cadastro do
/// assinante (CLINICA), então checar de novo seria redundante aqui. Isto
/// aprova especificamente a ATUAÇÃO como supervisor na plataforma (decisão
/// do admin, não do titular que cria a conta). Null = não é candidato a
/// supervisor (role != SUPERVISOR).
enum SupervisorApprovalStatus {
  PENDENTE
  APROVADO
  REJEITADO
}

enum EnrollmentSource {
  ASSINATURA
  MARKETPLACE
}

enum LeadStage {
  NOVO
  CONTATADO
  AGENDADO
  CONVERTIDO
  PERDIDO
}

/// Um tenant = uma conta de psicólogo(a)/clínica OU uma conta individual de
/// estudante (ver TenantKind). Toda tabela clínica carrega tenantId e é
/// protegida por Row-Level Security (ver prisma/rls.sql).
model Tenant {
  id   String     @id @default(uuid())
  name String
  slug String     @unique
  kind TenantKind @default(CLINICA)

  /// Sub-conta no gateway de pagamento nacional (ex: Asaas) que recebe
  /// diretamente os pagamentos de pacientes ao psicólogo — ver Invoice.
  /// A plataforma nunca retém esse dinheiro, então não é responsável por
  /// declarar ganhos/impostos do assinante.
  payoutProvider  String?
  payoutAccountId String?

  /// Conteúdo do Site Profissional (página pública em /p/{slug}). Não tem RLS
  /// de propósito — GET público não passa por AuthMiddleware, então nunca há
  /// app.tenant_id setado nessa rota; ver profile.service.ts.
  /// Apresentação pessoal, curta — usada no topo (hero) da página pública.
  bio            String?
  /// Descrição de como funciona o atendimento (método, formato, o que esperar)
  /// — usada na seção "Sobre o atendimento", separada do bio pra não repetir
  /// o mesmo texto duas vezes na página.
  attendanceInfo String?
  photoUrl     String?
  specialties  String?
  publicEmail  String?
  publicPhone  String?
  /// Chave de uma paleta fixa (ver apps/web/lib/site-palettes.ts) — escolhida
  /// pelo psicólogo, aplicada só na página pública (/p/{slug}), nunca no
  /// dashboard interno. Lista fechada de propósito, validada no DTO.
  colorPalette String  @default("salvia")
  published    Boolean @default(false)
  /// Opt-in separado de `published`: um psicólogo pode ter a página própria no
  /// ar (/p/{slug}) sem querer aparecer na busca pública agregada da home da
  /// plataforma (/profissionais) — ver DirectoryService. Falso por padrão.
  listedInDirectory Boolean @default(false)

  /// Preço fixo da sessão, em centavos — exibido na página pública (Site
  /// Profissional) só quando preenchido, e usado pra gerar o Invoice
  /// automaticamente no agendamento público (ver AvailabilitySlot). Null
  /// enquanto o psicólogo não configurar.
  sessionPriceCents Int?
  /// Liga/desliga o widget de agendamento público na página /p/{slug}. Fica
  /// falso por padrão mesmo com horários liberados, pra evitar expor a função
  /// antes do psicólogo confirmar que quer aceitar reservas com cobrança.
  bookingEnabled    Boolean @default(false)

  createdAt DateTime @default(now())

  users              User[]
  patients           Patient[]
  prontuarioEntries  ProntuarioEntry[]
  homeworks          Homework[]
  appointments       Appointment[]
  availabilitySlots  AvailabilitySlot[]
  invoices           Invoice[]
  subscription       Subscription?
  enrollments        CourseEnrollment[]
  testAssignments    TestAssignment[]
  moduleProgress     ModuleProgress[]
  certificates       Certificate[]
  courseQuizAttempts CourseQuizAttempt[]
  supervisionSessions SupervisionSession[]
  supervisionMessages SupervisionMessage[]
  leads              Lead[]
  leadActivities     LeadActivity[]
  communityPosts     CommunityPost[]
  communityReplies   CommunityReply[]
  aiUsageLogs        AiUsageLog[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String
  name         String
  role         Role
  createdAt    DateTime @default(now())

  /// Só relevante para role=PSICOLOGO_TITULAR num tenant kind=CLINICA. Rotas
  /// clínicas (Prontuário, Agenda, Teleconsulta) devem checar
  /// crpStatus=VERIFICADO antes de liberar acesso — estudante nunca atende.
  /// Ainda NÃO é checado em nenhum guard (ver README) — o fluxo de submissão/
  /// aprovação existe, mas bloquear acesso é uma decisão separada em aberto.
  crpNumber         String?
  crpStatus         CrpStatus @default(NAO_ENVIADO)
  /// Caminho local do documento enviado para análise (uploads/crp/, fora do
  /// diretório público) — ver users/crp.controller.ts. Nunca exposto direto
  /// por URL; só baixável pelo próprio titular ou pelo admin da plataforma.
  crpDocumentPath   String?
  /// Preenchido pelo admin ao rejeitar — mostrado pro psicólogo no banner de
  /// pendências pra ele saber o que corrigir antes de reenviar.
  crpRejectionReason String?

  /// Só setado quando role=SUPERVISOR (ver UsersService.createTeamMember).
  /// Enquanto não for APROVADO pelo admin da plataforma, este usuário não
  /// pode ser escolhido como supervisorId em SupervisionSession (ver
  /// SupervisionService.create). Acesso como supervisionado (superviseeId)
  /// é livre para qualquer psicólogo assinante, sem gate nenhum.
  supervisorApprovalStatus  SupervisorApprovalStatus?
  supervisorRejectionReason String?

  prontuarioEntries ProntuarioEntry[] @relation("AutorEntry")
  testsAssigned     TestAssignment[]  @relation("TestAssignedBy")
  testsCorrected    TestAssignment[]  @relation("TestCorrectedBy")
  moduleProgress    ModuleProgress[]
  certificates      Certificate[]
  courseQuizAttempts CourseQuizAttempt[]
  supervisionsGiven    SupervisionSession[] @relation("Supervisor")
  supervisionsReceived SupervisionSession[] @relation("Supervisee")
  supervisionMessagesAsSupervisor SupervisionMessage[] @relation("SupervisionMessageSupervisor")
  supervisionMessagesAsSupervisee SupervisionMessage[] @relation("SupervisionMessageSupervisee")
  supervisionMessagesSent         SupervisionMessage[] @relation("SupervisionMessageSender")
  assignedLeads        Lead[]           @relation("LeadAssignee")
  leadActivities       LeadActivity[]
  communityPosts       CommunityPost[]
  communityReplies     CommunityReply[]
  communityReports       CommunityReport[]
  communityLikes         CommunityLike[]
  communityNotifications CommunityNotification[]
  aiUsageLogs            AiUsageLog[]
  homeworksAssigned      Homework[]

  @@unique([tenantId, email])
  @@map("users")
}

model Patient {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  /// Nome social ou apelido — exibido no lugar do nome civil quando preenchido,
  /// sem substituir `name` (que segue sendo o nome legal usado em documentos).
  socialName String?
  email      String?
  phone      String?
  birthDate  DateTime?
  /// Paciente inativo continua com todo o histórico intacto, só some do
  /// seletor de agendamento e da listagem padrão (filtro "Ativos").
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  /// CPF/CNPJ do paciente — exigido pelo Asaas pra gerar cobrança real (ver
  /// AsaasService.createSplitCharge). Sem isso preenchido, a cobrança via
  /// Asaas é recusada com uma mensagem clara pedindo pra completar o cadastro.
  cpfCnpj String?

  /// Aplicativo do Paciente: identidade separada dos Users da equipe (staff
  /// tem crpStatus/Role, paciente não — são dois sistemas de login distintos
  /// de propósito, ver auth/patient-auth.middleware.ts). `portalEnabled` só
  /// vira true quando a equipe ativa o acesso e define a senha inicial.
  passwordHash  String?
  portalEnabled Boolean @default(false)
  /// Autoatendimento: em vez da equipe definir a senha direto (fluxo antigo,
  /// ainda existe), a equipe gera esse token e manda o link pro paciente
  /// (WhatsApp, SMS — sem infra de e-mail neste projeto). Paciente abre o
  /// link, define a própria senha, token é limpo. Expira em 48h por padrão.
  activationToken          String?   @unique
  activationTokenExpiresAt DateTime?

  prontuarioEntries ProntuarioEntry[]
  appointments      Appointment[]
  invoices          Invoice[]
  testAssignments   TestAssignment[]
  convertedFromLead Lead?
  courseEnrollments  CourseEnrollment[]
  moduleProgress     ModuleProgress[]
  courseQuizAttempts CourseQuizAttempt[]
  certificates       Certificate[]
  homeworks          Homework[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("patients")
}

/// Entrada de evolução do prontuário. Nunca é editada após criada (append-only)
/// para atender a trilha de auditoria exigida pela Resolução CFP nº 06/2019.
model ProntuarioEntry {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, map: "prontuario_tenant_fk")
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("AutorEntry", fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([tenantId, patientId])
  @@map("prontuario_entries")
}

/// Tarefa que o psicólogo atribui a um paciente entre sessões (ex: "escreva 3
/// situações que geraram ansiedade essa semana") — mesmo padrão de
/// TestAssignment (atribui -> paciente responde -> fica visível pro
/// psicólogo), mas sem correção/pontuação, só um texto livre de instruções e
/// uma resposta livre opcional do paciente ao marcar como feito.
model Homework {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId    String
  patient      Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  assignedById String
  assignedBy   User      @relation(fields: [assignedById], references: [id])
  title        String
  instructions String
  status       String    @default("pendente")
  dueDate      DateTime?
  /// Preenchido pelo paciente ao marcar como concluído — opcional, é só um espaço pra comentar, não uma resposta corrigível.
  patientNote  String?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([tenantId, patientId])
  @@map("homeworks")
}

model Appointment {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  status    String   @default("agendado")
  createdAt DateTime @default(now())

  /// Teleconsulta (Daily.co). `consentAt` é o consentimento informado exigido
  /// pela Resolução CFP nº 11/2018 — a sala só aparece pro paciente no
  /// Aplicativo do Paciente depois de ele registrar consentimento; ver
  /// patient-portal.service.ts.
  videoRoomUrl  String?
  videoRoomName String?
  consentAt     DateTime?

  /// Preenchido quando status vira "cancelado" ou "falta" — motivo/observação.
  cancelReason String?

  invoices Invoice[]
  availabilitySlot AvailabilitySlot?

  @@index([tenantId, startsAt])
  @@map("appointments")
}

/// Horário que o psicólogo libera na própria Agenda pra aparecer como
/// disponível no widget de agendamento público (/p/{slug}). Existe separado
/// de Appointment porque precisa de um estado intermediário ("reservado,
/// aguardando pagamento") com prazo de expiração — Appointment sozinho não
/// tem isso. Ciclo de vida: disponivel -> reservado (visitante escolheu,
/// aguarda pagamento por 15min, ver BookingService) -> confirmado (Asaas
/// confirmou o pagamento, ver AsaasService.handleWebhook) ou de volta pra
/// disponivel (expirou sem pagar). Não há job/cron nenhum no projeto — a
/// expiração é verificada sob demanda (toda leitura de disponibilidade, ver
/// BookingService.expireStaleHolds) em vez de um worker em background.
model AvailabilitySlot {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  status    String   @default("disponivel")
  /// Só setado quando status="reservado" — se `now() > heldUntil` e ainda
  /// "reservado", a próxima leitura libera o horário de volta.
  heldUntil DateTime?
  createdAt DateTime @default(now())

  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([tenantId, startsAt])
  @@map("availability_slots")
}

/// Cobrança do psicólogo ao PACIENTE (Financeiro) — dinheiro vai direto para
/// Tenant.payoutAccountId no gateway nacional, nunca passa pelo caixa da
/// plataforma. Diferente de Subscription, que é o psicólogo pagando a
/// plataforma.
model Invoice {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  amountCents Int
  status      String   @default("pendente")
  dueDate     DateTime
  /// Carimbado quando status vira "pago"; limpo se reverter. Base pro resumo
  /// financeiro (recebido no mês) em vez de usar dueDate como proxy.
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  /// Sessão de origem da cobrança, opcional — não obrigatório porque cobrança
  /// avulsa (ex: pacote de sessões) também é um caso real.
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  /// Cobrança real via Asaas, com split pro payoutAccountId do Tenant — ver
  /// AsaasService.createSplitCharge. Fica null enquanto a cobrança for só o
  /// registro manual do F1 (sem gateway ligado).
  asaasPaymentId String?
  paymentLink    String?

  @@index([tenantId])
  @@map("invoices")
}

/// Catálogo de testes/escalas — GLOBAL, sem tenantId, porque é conteúdo
/// compartilhado entre todas as clínicas (como CourseVideo). Só o admin
/// da plataforma cadastra/edita (ver admin/tests.*, cadastro manual). Cada
/// template tem perguntas objetivas (múltipla escolha, usando responseScale)
/// e/ou subjetivas (texto livre, sem pontuação).
model TestTemplate {
  id           String @id @default(uuid())
  slug         String @unique
  title        String
  /// Subgrupo livre (ex: "Ansiedade", "Depressão", "Carreira") — texto, não
  /// enum, pra admin poder criar categorias novas sem mudar código.
  category     String
  source       String
  disclaimer   String
  instructions String
  /// Escala compartilhada pelas perguntas objetivas deste template (ex: 0-3,
  /// "Nunca".."Quase todos os dias"). Perguntas subjetivas ignoram isso.
  responseScale Json?
  /// Faixas de pontuação pra SUGERIR um resultado a partir da soma das
  /// respostas objetivas SEM subescala — sempre revisável pelo psicólogo.
  scoreBands    Json?
  /// Definição das subescalas do instrumento (ex: YSQ tem 18 esquemas,
  /// Seligman tem 6 dimensões): array de { key, label, scoreBands? }. Cada
  /// TestQuestion.subscale referencia uma `key` daqui. Instrumentos simples
  /// (soma única) deixam isso null e usam scoreBands acima.
  subscales     Json?
  /// Escores compostos calculados a partir das subescalas (ex: Seligman
  /// "Total S - Total I"): array de { key, label, formula: [{ subscale,
  /// weight }], scoreBands? }. Ver scoring.ts.
  derivedScores Json?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  questions   TestQuestion[]
  assignments TestAssignment[]

  @@map("test_templates")
}

model TestQuestion {
  id             String       @id @default(uuid())
  testTemplateId String
  testTemplate   TestTemplate @relation(fields: [testTemplateId], references: [id], onDelete: Cascade)
  order          Int
  /// "objetiva" usa TestTemplate.responseScale (ou `options` abaixo, se
  /// preenchido); "subjetiva" é texto livre.
  type           String
  prompt         String
  /// Item de pontuação invertida (comum em escalas psicométricas reais, ex:
  /// Rosenberg) — na correção, o valor vira (min+max da escala usada) - valor
  /// escolhido, em vez de somado direto. Ver scoring.ts. Não combinar com
  /// `options` preenchido — instrumentos com opções por item (ex: HAD, BDI)
  /// já codificam a direção certa na própria ordem das opções.
  reverseScored  Boolean @default(false)
  /// Opções específicas desta pergunta — sobrepõe TestTemplate.responseScale
  /// quando preenchido. Necessário pra escalas onde cada item tem frases de
  /// resposta próprias (ex: HAD, Beck), não uma escala Likert compartilhada.
  options        Json?
  /// Referencia uma `key` de TestTemplate.subscales — em instrumentos com
  /// múltiplas subescalas (ex: YSQ, Seligman), diz a qual dimensão este item
  /// pertence. Null = item conta pro escore geral (TestTemplate.scoreBands).
  subscale       String?

  @@index([testTemplateId])
  @@map("test_questions")
}

/// Um teste disponibilizado a um paciente específico (Aplicação de Testes).
/// Ciclo de vida: pendente (psicólogo disponibilizou, paciente ainda não
/// respondeu) -> respondido (paciente enviou; sem opção de refazer) ->
/// corrigido (psicólogo revisou/pontuou e decidiu como comunicar). O
/// paciente NUNCA vê score/resultLabel por este sistema — comunicar o
/// resultado é sempre decisão manual do psicólogo, nunca automática (mesma
/// cautela já documentada no disclaimer do GAD-7).
model TestAssignment {
  id             String       @id @default(uuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId      String
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  testTemplateId String
  testTemplate   TestTemplate @relation(fields: [testTemplateId], references: [id])

  assignedById String
  assignedBy   User     @relation("TestAssignedBy", fields: [assignedById], references: [id])
  assignedAt   DateTime @default(now())

  status String @default("pendente")

  /// Respostas brutas do paciente: { [questionId]: number | string }.
  answers     Json?
  submittedAt DateTime?
  /// Soma automática das perguntas objetivas — só sugestão, nunca o valor
  /// final (ver finalScore/finalResultLabel).
  suggestedScore       Int?
  suggestedResultLabel String?
  /// Escores por subescala calculados na submissão (ver scoring.ts): array
  /// de { key, label, score, resultLabel }. Só preenchido quando o template
  /// usa TestTemplate.subscales. Sempre sugestão — nunca o valor final.
  suggestedSubscaleScores Json?
  /// Escores compostos calculados na submissão a partir de derivedScores.
  suggestedDerivedScores  Json?

  finalScore       Int?
  finalResultLabel String?
  /// Como/se o psicólogo decidiu comunicar o resultado ao paciente — nunca
  /// exibido automaticamente na área do paciente.
  communicationNote String?
  correctedAt       DateTime?
  correctedById     String?
  correctedBy       User?     @relation("TestCorrectedBy", fields: [correctedById], references: [id])

  attachedToProntuario Boolean @default(false)
  prontuarioEntryId    String?

  @@index([tenantId, patientId])
  @@map("test_assignments")
}

/// Compra de curso avulso (Marketplace) OU acesso liberado por já ter
/// assinatura da plataforma completa — os dois casos usam o mesmo registro
/// para o player de curso checar acesso sem se importar com a origem.
/// tenant.kind=ESTUDANTE só existe para viabilizar este modelo: aluno de
/// psicologia compra o curso sem nunca abrir Prontuário/Agenda.
/// `tenantId` continua SEMPRE preenchido (mesmo em matrícula de paciente —
/// usa o tenant da clínica dele, ver PatientCoursesService): `course_enrollments`
/// tem RLS forçado, e a policy exige "tenantId" = tenant da sessão, então
/// deixar null quebraria o INSERT. `patientId` (opcional) identifica UM
/// paciente específico dentro desse tenant; null = matrícula da conta
/// ESTUDANTE inteira (fluxo clássico). A constraint de 3 colunas evita
/// colisão entre dois pacientes DIFERENTES da mesma clínica no mesmo curso
/// (patientId real, nunca null, nesse caso) — mas não impede uma conta
/// ESTUDANTE de gerar duas linhas com patientId null pro mesmo curso; isso é
/// prevenido a nível de aplicação (upsert/findFirst antes de criar), não pelo
/// banco, já que Postgres nunca considera NULL igual a NULL numa unique.
model CourseEnrollment {
  id                String           @id @default(uuid())
  tenantId          String
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId         String?
  patient           Patient?         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  courseSlug        String
  course            Course           @relation(fields: [courseSlug], references: [slug])
  source            EnrollmentSource
  priceCents        Int?
  paymentProvider   String?
  externalPaymentId String?
  createdAt         DateTime         @default(now())

  @@unique([tenantId, courseSlug, patientId])
  @@index([tenantId])
  @@map("course_enrollments")
}

/// Conclusão de uma aula por um usuário OU por um paciente (mutuamente
/// exclusivos, mesmo padrão de CourseEnrollment acima) — `lessonId` referencia
/// CourseLesson (catálogo admin-gerenciável, ver Course/CourseModule/
/// CourseLesson abaixo).
model ModuleProgress {
  id          String       @id @default(uuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  patientId   String?
  patient     Patient?     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt DateTime     @default(now())

  @@unique([userId, lessonId])
  @@unique([patientId, lessonId])
  @@index([tenantId])
  @@map("module_progress")
}

/// Emitido automaticamente quando um usuário OU paciente completa todas as
/// aulas obrigatórias (não-extra) de um curso (ver CoursesService). Sem RLS de
/// propósito — a verificação pública por `verificationCode` (como
/// autenticidade de diploma) não deve depender de contexto de tenant, e não
/// é dado clínico sensível. `tenantId` aqui não participa de nenhuma
/// constraint de unicidade (só referência/relatório), então pode ficar
/// preenchido com o tenant da clínica do paciente sem risco de colisão.
model Certificate {
  id                String   @id @default(uuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  patientId         String?
  patient           Patient? @relation(fields: [patientId], references: [id], onDelete: Cascade)
  courseSlug        String
  course            Course   @relation(fields: [courseSlug], references: [slug])
  verificationCode  String   @unique @default(uuid())
  issuedAt          DateTime @default(now())
  /// PNG renderizado automaticamente (nome+curso+data+código compostos sobre
  /// o CertificateTemplate vigente no momento da emissão) — relativo a
  /// uploads/certificates/. Null se nenhum CertificateTemplate estava
  /// configurado quando o certificado foi emitido (nunca re-renderizado
  /// retroativamente se o modelo mudar depois).
  filePath          String?

  @@unique([userId, courseSlug])
  @@unique([patientId, courseSlug])
  @@map("certificates")
}

/// Modelo visual ÚNICO (singleton — sempre uma linha só) usado para renderizar
/// TODOS os certificados emitidos, de qualquer curso. Posições em % (0-100)
/// relativas às dimensões da imagem enviada; fontSize em px, ajustado
/// olhando a pré-visualização (ver CertificatesService/renderer).
model CertificateTemplate {
  id             String   @id @default(uuid())
  imagePath      String
  nameX          Float    @default(50)
  nameY          Float    @default(45)
  nameFontSize   Int      @default(48)
  courseX        Float    @default(50)
  courseY        Float    @default(58)
  courseFontSize Int      @default(28)
  dateX          Float    @default(50)
  dateY          Float    @default(70)
  dateFontSize   Int      @default(18)
  codeX          Float    @default(50)
  codeY          Float    @default(92)
  codeFontSize   Int      @default(12)
  updatedAt      DateTime @updatedAt

  @@map("certificate_template")
}

/// Catálogo de cursos — GLOBAL, sem tenantId, cadastrado só pelo admin da
/// plataforma (nunca pelo psicólogo/clínica), no modelo de plataformas
/// comerciais (Hotmart/Udemy): Curso > Módulo > Aula, com aulas extras que
/// não entram na sequência obrigatória. Assinante (Tenant.kind=CLINICA) tem
/// acesso incluso na assinatura da plataforma; quem não assina compra avulso
/// via Marketplace (CourseEnrollment) e paga `priceCents`.
model Course {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String
  priceCents  Int?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  modules      CourseModule[]
  enrollments  CourseEnrollment[]
  certificates Certificate[]

  @@map("courses")
}

model CourseModule {
  id       String @id @default(uuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order    Int
  title    String
  /// Libera sem assinatura/matrícula — isca/lead-magnet (mesmo papel do
  /// antigo "bloco grátis").
  free     Boolean @default(false)

  lessons CourseLesson[]

  @@index([courseId])
  @@map("course_modules")
}

model CourseLesson {
  id          String       @id @default(uuid())
  moduleId    String
  module      CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  order       Int
  title       String
  description String?
  youtubeUrl  String?
  /// Aula extra/bônus: aparece à parte, nunca bloqueia nem é bloqueada pela
  /// sequência obrigatória de quiz das aulas principais do módulo.
  isExtra     Boolean @default(false)

  materials CourseLessonMaterial[]
  quiz      CourseQuiz?
  progress  ModuleProgress[]

  @@index([moduleId])
  @@map("course_lessons")
}

/// Material de apoio pra baixar, anexado pelo admin (apps/api/uploads/
/// course-materials/) — mesmo padrão de DocumentTemplate.
model CourseLessonMaterial {
  id       String       @id @default(uuid())
  lessonId String
  lesson   CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title    String
  filePath String

  @@index([lessonId])
  @@map("course_lesson_materials")
}

/// Quiz objetivo de uma aula. Diferente do módulo clínico de Testes: a nota
/// SEMPRE aparece pro aluno, e ele pode responder quantas vezes quiser — só
/// `required` (definido pelo admin) decide se precisa atingir
/// `passingScorePercent` antes da próxima aula não-extra do módulo abrir.
model CourseQuiz {
  id                  String       @id @default(uuid())
  lessonId            String       @unique
  lesson              CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  required            Boolean      @default(false)
  passingScorePercent Int          @default(70)

  questions CourseQuizQuestion[]
  attempts  CourseQuizAttempt[]

  @@map("course_quizzes")
}

model CourseQuizQuestion {
  id     String     @id @default(uuid())
  quizId String
  quiz   CourseQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  order  Int
  prompt String
  /// [{ "id": "a", "label": "..." }, ...]
  options         Json
  correctOptionId String

  @@index([quizId])
  @@map("course_quiz_questions")
}

/// Histórico completo de tentativas — nunca sobrescreve, pra sustentar
/// "responder quantas vezes desejar" com nota sempre visível.
model CourseQuizAttempt {
  id           String     @id @default(uuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  patientId    String?
  patient      Patient?   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  quizId       String
  quiz         CourseQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers      Json
  scorePercent Int
  passed       Boolean
  createdAt    DateTime   @default(now())

  @@index([tenantId, userId, quizId])
  @@map("course_quiz_attempts")
}

/// Sessão de supervisão clínica entre o psicólogo titular e um supervisor —
/// hoje só modela supervisor dentro do mesmo tenant (role=SUPERVISOR
/// cadastrado via POST /users); supervisor externo cross-tenant fica para
/// depois.
model SupervisionSession {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supervisorId String
  supervisor   User     @relation("Supervisor", fields: [supervisorId], references: [id])
  superviseeId String
  supervisee   User     @relation("Supervisee", fields: [superviseeId], references: [id])
  startsAt     DateTime
  endsAt       DateTime
  notes        String?
  status       String   @default("agendado")
  createdAt    DateTime @default(now())
  /// Sala Daily.co criada automaticamente ao agendar (ver
  /// SupervisionService.create/createTeleconsultaRoom) — mesmo padrão do
  /// Appointment, mas sem gate de consentAt (não é dado do paciente).
  videoRoomUrl  String?
  videoRoomName String?

  @@index([tenantId, startsAt])
  @@map("supervision_sessions")
}

/// Chat de texto entre uma dupla supervisor/supervisionado — thread contínua
/// pelo par (supervisorId, superviseeId), não presa a uma SupervisionSession
/// específica (conversa persiste entre sessões agendadas). Só pode existir
/// mensagem entre um par que já tem pelo menos uma SupervisionSession (ver
/// SupervisionService.resolvePair) — nunca DM livre entre quaisquer users.
model SupervisionMessage {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supervisorId String
  supervisor   User     @relation("SupervisionMessageSupervisor", fields: [supervisorId], references: [id])
  superviseeId String
  supervisee   User     @relation("SupervisionMessageSupervisee", fields: [superviseeId], references: [id])
  senderId     String
  sender       User     @relation("SupervisionMessageSender", fields: [senderId], references: [id])
  content      String
  createdAt    DateTime @default(now())

  @@index([tenantId, supervisorId, superviseeId, createdAt])
  @@map("supervision_messages")
}

/// Lead do funil de captação (CRM), antes de virar Patient. `convertToPatient`
/// (ver CrmService) cria o Patient de verdade e linka aqui — o histórico do
/// funil não se perde quando o lead vira paciente.
model Lead {
  id                 String    @id @default(uuid())
  tenantId           String
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name               String
  contact            String?
  source             String?
  stage              LeadStage @default(NOVO)
  notes              String?
  /// Responsável pelo lead (opcional) — útil em clínica com mais de um profissional.
  assignedToId       String?
  assignedTo         User?     @relation("LeadAssignee", fields: [assignedToId], references: [id])
  convertedPatientId String?   @unique
  convertedPatient   Patient?  @relation(fields: [convertedPatientId], references: [id])
  createdAt          DateTime  @default(now())

  activities LeadActivity[]

  @@index([tenantId])
  @@index([tenantId, assignedToId])
  @@map("leads")
}

/// Histórico cronológico (append-only) de interações com o lead — diferente
/// de Lead.notes (um campo único, sempre sobrescrito, pra status atual em
/// uma linha). Cada entrada aqui fica pra sempre, registrando quem fez o quê
/// e quando (ex: "liguei, sem resposta", "remarcado pra sexta").
model LeadActivity {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([tenantId, leadId, createdAt])
  @@map("lead_activities")
}


/// Categorias fixas do fórum — lista fechada de propósito (como LeadStage),
/// pra manter o feed organizado sem virar taxonomia livre descontrolada.
enum CommunityCategory {
  INDICACAO
  CASO_CLINICO
  GESTAO_CONSULTORIO
  ABORDAGENS_TECNICAS
  CARREIRA_FORMACAO
  GERAL
}

/// Comunidade é o único espaço deliberadamente CROSS-TENANT do sistema — troca
/// de caso/indicação entre assinantes de clínicas diferentes. Por isso, ao
/// contrário de toda outra tabela, NÃO tem RLS: tenantId aqui é só atribuição
/// ("postado por qual clínica"), não isolamento. Ver prisma/rls.sql.
///
/// `authorName`/`tenantName`/`authorCrpVerified`/`authorSpecialty` são
/// snapshot de texto, não join ao vivo: `users` e `tenants` têm RLS, e uma
/// conexão sem app.tenant_id setado (o caso normal aqui, já que é leitura
/// cross-tenant) nunca conseguiria montar esse join — o Prisma erraria com
/// "Field author is required... got null". Capturados uma vez na criação,
/// quando o autor está no próprio contexto autenticado dele. Por serem
/// snapshot, um selo "CRP verificado" continua valendo mesmo se o status
/// mudar depois — reflete a situação NO MOMENTO da postagem, não ao vivo.
///
/// `removedAt`/`removedReason`: soft-delete pela moderação do admin da
/// plataforma (ver admin.service.ts) — a linha continua existindo pra
/// auditoria, só some da listagem padrão.
model CommunityPost {
  id                String            @id @default(uuid())
  tenantId          String
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantName        String
  authorId          String
  author            User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorName        String
  authorCrpVerified Boolean           @default(false)
  authorSpecialty   String?
  category          CommunityCategory @default(GERAL)
  title             String
  content           String
  createdAt         DateTime          @default(now())
  removedAt         DateTime?
  removedReason     String?

  replies       CommunityReply[]
  reports       CommunityReport[]
  likes         CommunityLike[]
  notifications CommunityNotification[]

  @@index([category, createdAt])
  @@map("community_posts")
}

model CommunityReply {
  id                String        @id @default(uuid())
  postId            String
  post              CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tenantId          String
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantName        String
  authorId          String
  author            User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorName        String
  authorCrpVerified Boolean       @default(false)
  authorSpecialty   String?
  content           String
  createdAt         DateTime      @default(now())
  removedAt         DateTime?
  removedReason     String?

  reports       CommunityReport[]
  likes         CommunityLike[]
  notifications CommunityNotification[]

  @@index([postId])
  @@map("community_replies")
}

/// Fila de denúncias pro admin da plataforma revisar — post OU resposta,
/// nunca os dois (exatamente um dos dois FKs preenchido).
model CommunityReport {
  id         String          @id @default(uuid())
  postId     String?
  post       CommunityPost?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  replyId    String?
  reply      CommunityReply? @relation(fields: [replyId], references: [id], onDelete: Cascade)
  reporterId String
  reporter   User            @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reason     String
  createdAt  DateTime        @default(now())
  resolvedAt DateTime?

  @@index([resolvedAt])
  @@map("community_reports")
}

/// Curtida em post OU resposta (exatamente um dos dois FKs preenchido) — os
/// dois `@@unique` abaixo garantem no máximo uma curtida por usuário em cada
/// post/resposta (funciona mesmo com o outro campo null: Postgres nunca
/// considera dois NULLs iguais, então a constraint relevante em cada caso é
/// sempre a que tem o campo populado).
model CommunityLike {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String?
  post      CommunityPost?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  replyId   String?
  reply     CommunityReply? @relation(fields: [replyId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  @@unique([userId, postId])
  @@unique([userId, replyId])
  @@index([postId])
  @@index([replyId])
  @@map("community_likes")
}

/// Notificação in-app (sem infra de e-mail/push neste projeto) — criada
/// quando alguém responde a um post, pro autor do post. Nunca notifica o
/// próprio autor respondendo a si mesmo.
model CommunityNotification {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      CommunityPost   @relation(fields: [postId], references: [id], onDelete: Cascade)
  replyId   String?
  reply     CommunityReply? @relation(fields: [replyId], references: [id], onDelete: Cascade)
  message   String
  readAt    DateTime?
  createdAt DateTime        @default(now())

  @@index([userId, readAt])
  @@map("community_notifications")
}

/// Registro de cada chamada de IA (ver AiService) — existe só pra sustentar o
/// limite diário por clínica (sem isso, nenhum controle de custo existia:
/// qualquer usuário podia chamar o assistente sem limite nenhum). `feature`
/// identifica qual função gerou a chamada ('ask' | 'prontuario_summary' |
/// 'lead_followup'), tokens vêm da resposta real da Anthropic (não estimado).
model AiUsageLog {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature      String
  inputTokens  Int?
  outputTokens Int?
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@map("ai_usage_logs")
}

/// Assinatura do tenant na própria plataforma (billing do Portal do Psi,
/// não confundir com Invoice, que é a cobrança do psicólogo ao paciente).
model Subscription {
  id                   String             @id @default(uuid())
  tenantId             String             @unique
  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  /// Asaas é o gateway principal para assinatura da plataforma (§03 do doc de
  /// arquitetura); Stripe fica secundário, hoje só usado pelo Marketplace.
  asaasCustomerId      String?
  asaasSubscriptionId  String?
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())

  @@map("subscriptions")
}

/// Modelo de documento (contrato, termo, recibo) enviado pelo admin —
/// apps/api/uploads/document-templates/, fora de pasta pública. Igual a
/// CourseModuleVideo, sem RLS: conteúdo global, só o admin escreve. A
/// restrição de "só assinante CLINICA vê" é feita no service de leitura
/// (DocumentTemplatesService), não no banco — mesmo padrão do bloco gratuito
/// em CoursesService.
model DocumentTemplate {
  id          String   @id @default(uuid())
  title       String
  description String
  filePath    String
  createdAt   DateTime @default(now())

  @@map("document_templates")
}

/// Biblioteca de materiais (Biblioteca no menu) — apostilas, planilhas,
/// artigos, áudios etc. em qualquer formato, organizados por categoria livre
/// (igual TestTemplate.category), enviados pelo admin e baixados pelo
/// assinante (tenant.kind=CLINICA). Mesmo padrão de storage/RLS do
/// DocumentTemplate: arquivo em apps/api/uploads/library-materials/, sem
/// RLS (conteúdo global, só admin escreve), restrição de acesso feita no
/// service de leitura (LibraryService) + EstudanteAccessGuard.
model LibraryMaterial {
  id          String   @id @default(uuid())
  category    String
  title       String
  description String?
  filePath    String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("library_materials")
}

/// Banner promocional da home pública da PLATAFORMA (/, não confundir com a
/// página do psicólogo em /p/{slug}) — só 2 posições fixas (1 e 2), geridas
/// pelo admin. Imagem fica em apps/api/uploads/banners/, servida por rota
/// pública dedicada (igual profile-photo-upload.config.ts) porque precisa
/// aparecer pra visitante sem login. Sem RLS/tenantId de propósito: conteúdo
/// global da plataforma, só o admin escreve (mesmo motivo de DocumentTemplate).
model Banner {
  id        String   @id @default(uuid())
  position  Int      @unique
  imageUrl  String
  linkUrl   String?
  active    Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("banners")
}

/// Singleton (sempre uma linha só, ver PlatformSettingsService) — paleta de
/// cores da plataforma em si (home pública, logins, loja de cursos, painéis
/// internos), escolhida pelo admin. Não confundir com Tenant.colorPalette,
/// que é a paleta da página individual de CADA psicólogo (/p/{slug}) — essa
/// aqui é uma escolha só, valendo pro resto do site inteiro.
model PlatformSettings {
  id           String @id @default(uuid())
  colorPalette String @default("salvia")

  @@map("platform_settings")
}

