# Postgres — sem Docker disponível localmente, use um Postgres gerenciado gratuito
# para desenvolvimento (ex: Neon, Supabase) ou uma instalação local do Postgres 15+.
# NUNCA use a role "postgres" (superusuário) aqui — ela ignora RLS incondicionalmente,
# mesmo com FORCE ROW LEVEL SECURITY, e todo o isolamento entre tenants para de
# funcionar silenciosamente. Crie uma role de aplicação dedicada (ver README, seção 1).
DATABASE_URL="postgresql://portal_app:password@localhost:5432/portal_do_psi?schema=public"

# Gerar um valor aleatório longo, ex: `openssl rand -hex 32`
JWT_SECRET="troque-este-valor"
JWT_EXPIRES_IN="7d"

PORT=3333

# Preencher quando a conta Stripe (modo teste) existir — ver apps/api/src/billing/billing.service.ts
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Pasta que contém Formacao-Neurociencia/ e Escola-Marketing-Psicologos/ — por padrão
# assume o layout deste repositório (três níveis acima de apps/api, "C:\Claude local").
# Só precisa preencher se você mover o repo ou as pastas de curso para outro lugar.
COURSES_ROOT=""

# Preencher com uma chave da sua própria conta Anthropic para habilitar IA
# Clínica/Assistente IA — ver apps/api/src/ai/ai.service.ts. Sem isso, os
# endpoints /ai/* respondem 503.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"

# Preencher com uma chave da sua própria conta Daily.co para habilitar
# Teleconsulta — ver apps/api/src/teleconsulta/teleconsulta.service.ts. Sem
# isso, criar sala de vídeo responde 503.
DAILY_API_KEY=""

# Preencher com uma chave da sua própria conta Asaas (sandbox ou produção)
# para habilitar o gateway nacional (assinatura da plataforma, sub-conta do
# psicólogo, cobrança de paciente com split) — ver apps/api/src/asaas/asaas.service.ts.
# Sem isso, os endpoints /asaas/* e o botão "cobrar via Asaas" no Financeiro
# respondem 503.
ASAAS_API_KEY=""
ASAAS_BASE_URL="https://api-sandbox.asaas.com/v3"
# Token que você mesmo configura no painel do Asaas para autenticar o webhook
# (header asaas-access-token) — opcional em dev, recomendado em produção.
ASAAS_WEBHOOK_TOKEN=""
# Percentual retido pela plataforma em cada cobrança de paciente antes do
# split pro psicólogo (0 = repassa 100% pro psicólogo).
ASAAS_PLATFORM_FEE_PERCENT="0"

# Segredo único do console do administrador da plataforma (não é um tenant) —
# gere um valor aleatório longo, ex: `openssl rand -hex 24`. Protege /admin/*
# (revisão de CRP, Ofertas) via header x-admin-token. Sem isso, /admin/*
# responde 503.
ADMIN_TOKEN=""

# IDs de Price já criados no seu painel do Stripe para os dois planos da
# assinatura (R$150/mês, R$1500/ano) — não são fabricáveis, precisam existir
# de verdade no Stripe antes do checkout funcionar. Sem isso, o botão "Assinar
# via cartão" na página Assinatura responde 503; via Asaas funciona sem isso.
STRIPE_PRICE_MONTHLY=""
STRIPE_PRICE_YEARLY=""
